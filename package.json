{
  "name": "meteoracle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "worker": "tsx --tsconfig tsconfig.worker.json worker.ts",
    "worker:build": "tsc --project tsconfig.worker.json",
    "worker:start": "node -r tsconfig-paths/register dist/worker.js",
    "postinstall": "node scripts/patch-dlmm-esm.js"
  },
  "overrides": {
    "@meteora-ag/dlmm": {
      "exports": {
        ".": {
          "require": "./dist/index.cjs",
          "import": "./dist/index.cjs",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "dependencies": {
    "@meteora-ag/cp-amm-sdk": "^1.0.0",
    "@meteora-ag/dlmm": "^1.1.12",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/kv": "^3.0.0",
    "axios": "^1.7.9",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.18",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
