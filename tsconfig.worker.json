{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "worker.ts",
    "bot/**/*.ts",
    "lib/**/*.ts",
    "strategies/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "components",
    ".next"
  ]
}
