# =============================================================================
# METEORACLE — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked REQUIRED must be set or the process will not start.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED (dashboard + all bot processes)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # public — safe in dashboard
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # secret — server/bot only, never expose

# -----------------------------------------------------------------------------
# Solana RPC — REQUIRED (bot processes)
# Get a free key at https://helius.dev
# -----------------------------------------------------------------------------
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# -----------------------------------------------------------------------------
# Wallet — REQUIRED (executor)
# Base58-encoded private key of the wallet the bot will trade from.
# NEVER commit this value. Keep it out of version control.
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Telegram — REQUIRED (alerts + command bot)
# Create a bot via @BotFather to get the token.
# Get your chat ID by messaging @userinfobot.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Jupiter API — OPTIONAL
# Improves SOL price accuracy. Free key at https://dev.jup.ag
# -----------------------------------------------------------------------------
JUPITER_API_KEY=

# -----------------------------------------------------------------------------
# Bot control
# Set BOT_DRY_RUN=false only when you are ready to trade real funds.
# -----------------------------------------------------------------------------
BOT_DRY_RUN=true

# -----------------------------------------------------------------------------
# Position sizing & risk limits
# These are hard ceilings — individual strategy configs cannot exceed them.
# -----------------------------------------------------------------------------
MAX_SOL_PER_POSITION=0.05          # max SOL deployed per LP position
MAX_TOTAL_SOL_DEPLOYED=1           # max SOL across all open positions combined
MAX_CONCURRENT_POSITIONS=5         # max simultaneous open positions

# Wallet reserve floor = MAX_CONCURRENT_POSITIONS × MAX_SOL_PER_POSITION × WALLET_RESERVE_MULTIPLIER
# At defaults: 5 × 0.05 × 1.5 = 0.375 SOL always kept in wallet.
WALLET_RESERVE_MULTIPLIER=1.5

# -----------------------------------------------------------------------------
# Scanner settings
# -----------------------------------------------------------------------------
LP_SCAN_INTERVAL_SEC=900           # seconds between pool scans (default: 15 min)
MIN_SCORE_TO_OPEN=65               # minimum candidate score required to open a position

# -----------------------------------------------------------------------------
# Monitor settings
# -----------------------------------------------------------------------------
LP_MONITOR_INTERVAL_SEC=60         # seconds between position health checks (default: 1 min)

# -----------------------------------------------------------------------------
# Internal flags — set automatically by ecosystem.config.cjs
# Do not set these manually.
# LP_SCANNER_STANDALONE=true
# LP_MONITOR_STANDALONE=true
# -----------------------------------------------------------------------------
