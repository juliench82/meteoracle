# =============================================================================
# METEORACLE — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked REQUIRED must be set or the process will crash.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED for all processes (dashboard + all bots)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # public, safe to expose in dashboard
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # REQUIRED by bots — keep secret, server only

# -----------------------------------------------------------------------------
# Solana RPC — REQUIRED by all bot processes (not needed by dashboard)
# -----------------------------------------------------------------------------
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# -----------------------------------------------------------------------------
# Wallet — REQUIRED by executor
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY=                         # base58 private key — NEVER commit this

# -----------------------------------------------------------------------------
# Telegram — REQUIRED for alerts
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                         # from @BotFather
TELEGRAM_CHAT_ID=                           # your personal or group chat ID

# -----------------------------------------------------------------------------
# Bot control
# -----------------------------------------------------------------------------
BOT_DRY_RUN=true                            # set to false for live trading
MIN_WALLET_BALANCE_SOL=0.05                 # never open position if wallet drops below this

# -----------------------------------------------------------------------------
# Meteora DLMM LP — scanner
# -----------------------------------------------------------------------------
LP_SCAN_INTERVAL_SEC=900                    # seconds between Meteora pool scans (default 15min)
MIN_SCORE_TO_OPEN=65                        # min scorer score to open LP position
MAX_CONCURRENT_POSITIONS=5                  # max simultaneous LP positions

# Meteora DLMM LP — monitor
LP_MONITOR_INTERVAL_SEC=300                 # seconds between LP health checks (default 5min)

# Standalone flags — set automatically by ecosystem.config.cjs, do not set manually
# LP_SCANNER_STANDALONE=true
# LP_MONITOR_STANDALONE=true
