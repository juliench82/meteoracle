# =============================================================================
# METEORACLE — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked REQUIRED must be set or the process will crash.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED for all processes (dashboard + all bots)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # public, safe to expose in dashboard
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # REQUIRED by bots — keep secret, server only

# -----------------------------------------------------------------------------
# Solana RPC — REQUIRED by all bot processes (not needed by dashboard)
# -----------------------------------------------------------------------------
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# -----------------------------------------------------------------------------
# Wallet — REQUIRED by buyer, seller, executor, migrator
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY=                         # base58 private key — NEVER commit this

# -----------------------------------------------------------------------------
# Telegram — REQUIRED for alerts
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                         # from @BotFather
TELEGRAM_CHAT_ID=                           # your personal or group chat ID

# -----------------------------------------------------------------------------
# Bot control
# -----------------------------------------------------------------------------
BOT_DRY_RUN=true                            # set to false for live trading
MIN_WALLET_BALANCE_SOL=0.05                 # never buy if wallet drops below this

# -----------------------------------------------------------------------------
# Pipeline 2: Pre-grad spot buy — scanner
# -----------------------------------------------------------------------------
PRE_GRAD_POLL_INTERVAL_S=60                 # seconds between scanner polls
PRE_GRAD_WATCH_WINDOW_H=6                   # hours before watchlist entry expires
PRE_GRAD_MIN_MCAP=50000                     # min market cap USD to consider

# Pipeline 2: Pre-grad filters (all optional — defaults shown)
PRE_GRAD_MIN_BONDING_PCT=88                 # min bonding curve progress %
PRE_GRAD_MAX_BONDING_PCT=98                 # max bonding curve progress %
PRE_GRAD_MIN_VOL_5MIN_SOL=8                 # min 5-min volume in SOL
PRE_GRAD_MIN_HOLDERS=100                    # min holder count
PRE_GRAD_MAX_TOP_HOLDER=12                  # max top-holder concentration %
PRE_GRAD_MAX_DEV_WALLET_PCT=3               # max dev wallet concentration %
PRE_GRAD_MIN_VELOCITY=0                     # min curve progress pct/min (0 = disabled)

# Pipeline 2: Position sizing
SPOT_BUY_SOL=0.05                           # SOL per buy
MAX_CONCURRENT_SPOTS=3                      # max simultaneous open spot positions
MAX_TOTAL_SPOT_SOL=0.15                     # max total SOL deployed in spot positions
SPOT_BUY_SLIPPAGE_BPS=300                   # Jupiter slippage in basis points

# Pipeline 2: Exits
PRE_GRAD_TP_PCT=150                         # take profit %
PRE_GRAD_SL_PCT=-35                         # stop loss % (negative)
PRE_GRAD_MAX_HOLD_MIN=90                    # max hold time before force-close
PRE_GRAD_MIGRATE_LP=true                    # migrate bag to Meteora LP on graduation
PRE_GRAD_LP_PCT_BAG=50                      # % of token bag to put into LP

# Pipeline 2: Poll intervals
SPOT_BUYER_POLL_SEC=30
SPOT_MONITOR_POLL_SEC=30

# -----------------------------------------------------------------------------
# Pipeline 1: Meteora DLMM LP scanner
# -----------------------------------------------------------------------------
LP_SCAN_INTERVAL_SEC=900                    # seconds between Meteora pool scans (default 15min)
MIN_SCORE_TO_OPEN=65                        # min scorer score to open LP position
MAX_CONCURRENT_POSITIONS=5                  # max simultaneous LP positions

# Pipeline 1: LP monitor
LP_MONITOR_INTERVAL_SEC=300                 # seconds between LP health checks (default 5min)

# Standalone flags — set automatically by ecosystem.config.cjs, do not set manually
# LP_SCANNER_STANDALONE=true
# LP_MONITOR_STANDALONE=true
