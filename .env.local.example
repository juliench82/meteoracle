# =============================================================================
# METEORACLE — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked REQUIRED must be set or the process will not start.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — REQUIRED (dashboard + all bot processes)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY  # public — safe in dashboard
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY                        # secret — server/bot only, never expose

# -----------------------------------------------------------------------------
# Solana RPC — REQUIRED (bot processes)
# Get a free key at https://helius.dev
# HELIUS_RPC_URL is the normal primary RPC. HELIUS_API_KEY is also used to rebuild it if needed.
# -----------------------------------------------------------------------------
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=YOUR_KEY
HELIUS_ENABLED=true
HELIUS_HOLDER_MAX_PAGES=1
# Optional primary RPC override. Leave empty when using HELIUS_RPC_URL.
# RPC_URL=
# Optional comma-separated RPC fallbacks used for live position reads after the primary RPC fails.
SOLANA_RPC_FALLBACK_URLS=
# Keep false/empty unless you explicitly do not want read-only public fallback RPC.
DISABLE_PUBLIC_RPC_FALLBACK=false

# -----------------------------------------------------------------------------
# Wallet — REQUIRED (executor)
# Base58-encoded private key of the wallet the bot will trade from.
# NEVER commit this value. Keep it out of version control.
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY=
# Optional public key for read-only dashboard/portfolio fetches.
# If omitted, the public key is derived from WALLET_PRIVATE_KEY.
WALLET_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Telegram — REQUIRED (alerts + command bot)
# Create a bot via @BotFather to get the token.
# Get your chat ID by messaging @userinfobot.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user ids allowed to issue commands. Defaults to TELEGRAM_CHAT_ID if empty.
TELEGRAM_ALLOWED_USERS=
# Only needed if using the Next.js Telegram webhook route. PM2 long-polling does not need it.
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Bot control
# Set BOT_DRY_RUN=false only when you are ready to trade real funds.
# -----------------------------------------------------------------------------
BOT_ENABLED=false
BOT_DRY_RUN=true
# Only needed if calling /api/bot/tick over HTTP.
BOT_TICK_SECRET=

# -----------------------------------------------------------------------------
# Position sizing & risk limits
# These are hard ceilings — individual strategy configs cannot exceed them.
# -----------------------------------------------------------------------------
MAX_CONCURRENT_MARKET_LP_POSITIONS=3     # max simultaneous normal market LP positions
MAX_MARKET_LP_SOL_PER_POSITION=0.33      # max SOL per normal market LP position
MAX_MARKET_LP_SOL_DEPLOYED=0.99          # max SOL across normal market LP positions
MAX_CONCURRENT_DAMM_POSITIONS=2          # max simultaneous DAMM-edge positions

MAX_CONCURRENT_DAMM_MIGRATION_POSITIONS=1 # reserved DAMM migration opportunity slots
DAMM_MIGRATION_SOL_PER_POSITION=0.55      # SOL deployed when joining an official migrated DAMM v2 pool
MAX_DAMM_MIGRATION_SOL_DEPLOYED=0.55      # max SOL across DAMM migration positions
MAX_DAILY_LOSS_SOL=0                       # circuit breaker: max realized daily loss in SOL before opening new positions (0 disables)

# Backward-compatible fallbacks. Prefer the split caps above for live operation.
MAX_SOL_PER_POSITION=0.33
MAX_TOTAL_SOL_DEPLOYED=3
MAX_CONCURRENT_POSITIONS=4

# Executor reserve floor kept in wallet after position size + Meteora rent reserve.
WALLET_MIN_SOL_RESERVE=0.5
# Token reopening cooldowns after close/failure.
TOKEN_COOLDOWN_HOURS=6
TOKEN_EMERGENCY_COOLDOWN_HOURS=24

# -----------------------------------------------------------------------------
# Scanner settings
# -----------------------------------------------------------------------------
LP_SCAN_INTERVAL_SEC=900           # seconds between pool scans (default: 15 min)
MIN_SCORE_TO_OPEN=65               # minimum candidate score required to open a position
MAX_DEEP_CHECKS=12                 # max cheap-filter survivors to score deeply per scan
MAX_FRESH_DEEP_CHECKS=12           # max fresh-lane survivors to score deeply per scan
MAX_MOMENTUM_DEEP_CHECKS=12        # max momentum-lane survivors to score deeply per scan
DEEP_CHECK_DELAY_MS=3000           # delay between deep checks to avoid API bursts
CANDIDATE_DEDUP_HOURS=6            # do not reinsert same token as candidate within this window
FRESH_SCANNER_MAX_AGE_MINUTES=120  # fresh lane, based on Meteora pool_created_at
FRESH_MIN_VOLUME_5M_USD=2000       # fresh lane recent-volume floor; minMc is waived in this lane
MOMENTUM_POOL_LIMIT=500            # all-age lane only checks the top pools by volume_5m
MOMENTUM_MIN_VOLUME_5M_USD=5000    # all-age momentum lane absolute 5m volume floor
MOMENTUM_MIN_FEE_TVL_5M_PCT=0.1    # all-age momentum lane fee/TVL 5m floor, percent
SCALP_SPIKE_VOL_RATIO=2.5          # volume_5m / (volume_1h / 12) for scalp-spike class
SCALP_SPIKE_MIN_FEE_TVL_1H_PCT=1   # scalp-spike recent fee/TVL 1h floor, percent
SCALP_SPIKE_MIN_FEE_TVL_5M_PCT=0.1 # scalp-spike recent fee/TVL 5m floor, percent
SCALP_SPIKE_OOR_MINUTES=10         # scalp-spike OOR exit timer
SCALP_SPIKE_ENABLED=true           # set false to stop opening scalp-spike DLMM positions
EVIL_PANDA_ENABLED=true            # set false to stop opening evil-panda DLMM positions
DAMM_EDGE_ENABLED=false            # set true to enable DAMM-edge opens from scanner
EVIL_PANDA_MIN_HOLDER_COUNT_UNDER_60M=50

# -----------------------------------------------------------------------------
# DBC graduation watcher
# Watches Meteora Dynamic Bonding Curve pools before/at DAMM v2 migration.
# -----------------------------------------------------------------------------
DBC_GRADUATION_WATCH_INTERVAL_SEC=5
DBC_DISCOVERY_INTERVAL_SEC=60
DBC_WATCH_MIN_PROGRESS_PCT=85
DBC_OPEN_PROGRESS_PCT=100
DBC_MIN_SCORE_TO_OPEN=55
DBC_MIN_MIGRATION_QUOTE_SOL=5
DBC_RUGCHECK_GATE_ENABLED=true
DBC_MIN_RUGCHECK_SCORE=65
DBC_HOLDER_GATE_ENABLED=true
DBC_MIN_HOLDER_COUNT=100
DBC_MAX_TOP_HOLDER_PCT=35
DBC_REQUIRE_TOP_HOLDER_DATA=true
DBC_REQUIRE_RELIABLE_HOLDERS=false
DBC_AUTO_TRIGGER_MIGRATION=false
DBC_OPEN_MIGRATED_POSITION_ENABLED=false
DBC_USE_PROGRAM_SUBSCRIPTION=true
DBC_DISCOVERY_POLL_ENABLED=false
DBC_DISCOVERY_MAX_POOLS=1000
# Optional comma-separated virtual pool addresses to force-track instead of broad discovery.
DBC_WATCH_POOL_ADDRESSES=
# Optional override. Default is Meteora DBC mainnet/devnet program.
DBC_PROGRAM_ID=dbcij3LWUppWqq96dh6gJWwBifmcGfLSB5D4DuSMaqN
# Optional override. Default maps from the DBC pool migration fee option to Meteora's DAMM v2 config.
DAMM_MIGRATION_CONFIG_ADDRESS=

# -----------------------------------------------------------------------------
# Monitor settings
# -----------------------------------------------------------------------------
LP_MONITOR_INTERVAL_SEC=60         # seconds between position health checks (default: 1 min)
ORPHAN_CHECK_EVERY_N=1             # reconcile wallet positions from Meteora every N monitor ticks
LP_AUTO_REBALANCE_OOR=true         # close + reopen centered when OOR and pool health still passes
LP_SMART_REBALANCE_IN_RANGE=false  # optional; in-range drift rebalancing is off by default

# -----------------------------------------------------------------------------
# Swap cleanup settings
# -----------------------------------------------------------------------------
SWAP_SLIPPAGE_BPS=100              # Jupiter token->SOL cleanup slippage; no Jupiter API key is used

# -----------------------------------------------------------------------------
# Internal flags — set automatically by ecosystem.config.cjs
# Do not set these manually.
# LP_SCANNER_STANDALONE=true
# LP_MONITOR_STANDALONE=true
# -----------------------------------------------------------------------------
