# Solana RPC (Helius - https://helius.dev)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Set to 'true' only on paid Helius plan (free tier = 429s under scanner load)
# When false (default), scanner uses Meteora token.holders directly
HELIUS_ENABLED=false

# DAS holder lookup: set to 1+ only on paid Helius plan with DAS access
HELIUS_HOLDER_MAX_PAGES=0

# Wallet (base58 private key - NEVER commit this)
WALLET_PRIVATE_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Vercel KV (auto-injected by Vercel if you add KV store)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot config
BOT_ENABLED=false
BOT_DRY_RUN=true
MAX_SOL_PER_POSITION=0.5
MAX_CONCURRENT_POSITIONS=5

# Scanner config
MIN_SCORE_TO_OPEN=65
